{
	"name": "commonplace-notes-publisher",
	"version": "0.3.4",
	"description": "tbd",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"e2e": "npx playwright test --config=e2e/playwright.config.ts",
		"e2e:run": "npx tsx e2e/run-and-collect.ts",
		"e2e:run:quick": "npx tsx e2e/run-and-collect.ts --duration 10",
		"e2e:setup-vault": "npx tsx e2e/scripts/setup-vault.ts",
		"test:wikilinks": "npx tsx e2e/scripts/test-wikilinks.ts",
		"test:obscure-wikilinks": "npx tsx e2e/scripts/test-obscure-wikilinks.ts",
		"test:obscure-wikilinks-e2e": "npx tsx e2e/scripts/test-obscure-wikilinks-e2e.ts",
		"test:section-anchors": "npx tsx e2e/scripts/test-section-anchors.ts",
		"test:note-params": "npx tsx e2e/scripts/test-note-params.ts",
		"test:diff-params": "npx tsx e2e/scripts/test-diff-params.ts",
		"test:comment-sanitizer": "npx tsx e2e/scripts/test-comment-sanitizer.ts",
		"test:comment-loading": "npx tsx e2e/scripts/test-comment-loading.ts",
		"test:comment-identity": "npx tsx e2e/scripts/test-comment-identity.ts",
		"test:comment-edit-delete": "npx tsx e2e/scripts/test-comment-edit-delete.ts",
		"test:comment-threading": "npx tsx e2e/scripts/test-comment-threading.ts",
		"test:comment-wikilinks": "npx tsx e2e/scripts/test-comment-wikilinks.ts",
		"test:cert-match": "npx tsx e2e/scripts/test-cert-match.ts",
		"test:site-config-matrix": "npx tsx e2e/scripts/test-site-config-matrix.ts",
		"test:asset-customizations": "npx tsx e2e/scripts/test-asset-customizations.ts",
		"test:password-edge": "npx tsx e2e/scripts/test-password-edge.ts",
		"test:lambda-zip": "npx tsx e2e/scripts/test-lambda-zip.ts",
		"test:deployment-variants": "npx tsx e2e/scripts/deployment-variants-e2e.ts",
		"test:parser": "npx tsx e2e/scripts/test-parser-pipeline.ts",
		"test:parser:capture-golden": "npx tsx e2e/scripts/capture-parser-golden.ts > e2e/fixtures/parser-golden.json",
		"synth": "cd infrastructure && npm install && npx ts-node bin/synth.ts",
		"synth:site": "cd infrastructure && npx ts-node bin/synth-site-assets.ts"
	},
	"keywords": [],
	"author": "Zach Mueller",
	"license": "MIT",
	"engines": {
		"node": ">=24"
	},
